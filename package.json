{
  "name": "dataworks-platform",
  "version": "1.0.0",
  "description": "DataWorks - Data Engineering Service & Freelance Platform",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "server": "nodemon server/server.js",
    "client": "npm run dev --prefix Frontend-Newton-DataworksFreelance",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "install-all": "npm install && npm install --prefix Frontend-Newton-DataworksFreelance",
    "build": "npm run build --prefix Frontend-Newton-DataworksFreelance",
    "seed": "node server/seedJobs.js"
  },
  "keywords": [
    "dataworks",
    "data-engineering",
    "freelance",
    "mern",
    "react",
    "nodejs",
    "mongodb"
  ],
  "author": "DataWorks Team",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.3.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.6.3",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.1"
  }
}
